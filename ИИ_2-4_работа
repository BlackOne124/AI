for index, row in df.iterrows():
    if row['time'].month == 1:
        temp['Январь'] += row['T']
        month_count['Январь'] += 1
    elif row['time'].month == 2:
        temp['Февраль'] += row['T']
        month_count['Февраль'] += 1
    elif row['time'].month == 3:
        temp['Март'] += row['T']
        month_count['Март'] += 1
