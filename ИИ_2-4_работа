def direction_to_degrees(text):
    direction_map = {
        'с севера': 0, 'с северо-северо-востока': 22.5, 'с северо-востока': 45,
        'с востоко-северо-востока': 67.5, 'с востока': 90, 'с востоко-юго-востока': 112.5,
        'с юго-востока': 135, 'с юго-юго-востока': 157.5, 'с юга': 180,
        'с юго-юго-запада': 202.5, 'с юго-запада': 225, 'с западо-юго-запада': 247.5,
        'с запада': 270, 'с западо-северо-запада': 292.5, 'с северо-запада': 315,
        'с северо-северо-запада': 337.5, 'штиль': 0
    }
    text_lower = str(text).lower()
    for key, value in direction_map.items():
        if key in text_lower:
            return value
    return np.nan


