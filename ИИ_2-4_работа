DATE_COLUMN = 'Местное время в Рязани'
SNOW_COLUMN = 'sss'


if SNOW_COLUMN not in df.columns:
    print(f"Столбец '{SNOW_COLUMN}' отсутствует в данных.")

elif DATE_COLUMN not in df.columns:
    print(f"Столбец '{DATE_COLUMN}' отсутствует в данных.")

else:

    df[SNOW_COLUMN] = pd.to_numeric(df[SNOW_COLUMN], errors='coerce')


    df[DATE_COLUMN] = pd.to_datetime(df[DATE_COLUMN], errors='coerce', dayfirst=True)


    snow_data = df[[DATE_COLUMN, SNOW_COLUMN]].dropna().copy()

    if snow_data.empty:
        print("Нет данных о высоте снежного покрова.")
    else:

        snow_data['date'] = snow_data[DATE_COLUMN].dt.date


        daily_snow = snow_data.groupby('date')[SNOW_COLUMN].mean().reset_index()


        daily_snow = daily_snow.sort_values('date').reset_index(drop=True)

        daily_snow['snow_change'] = daily_snow[SNOW_COLUMN].diff()


        positive_changes = daily_snow[daily_snow['snow_change'] > 0]

        if positive_changes.empty:
            print("Не найдено дней с приростом снежного покрова.")
        else:

            max_gain_idx = positive_changes['snow_change'].idxmax()
